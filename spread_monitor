showZeroLevel = input.bool(true, "Показывать уровень нулевого спреда")

var line zeroSpreadLine = na
if showZeroLevel
    if na(zeroSpreadLine)
        zeroSpreadLine := line.new(bar_index, 0, bar_index + 1, 0, xloc=xloc.bar_index, extend=extend.both, color=color.new(color.white, 55), style=line.style_dotted, width=1)
    else
        line.set_xy1(zeroSpreadLine, bar_index, 0)
        line.set_xy2(zeroSpreadLine, bar_index + 1, 0)
        line.set_extend(zeroSpreadLine, extend.both)
        line.set_color(zeroSpreadLine, color.new(color.white, 55))
else if not na(zeroSpreadLine)
    line.delete(zeroSpreadLine)
    zeroSpreadLine := na

