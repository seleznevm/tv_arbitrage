//@version=6
indicator("Spread Monitor_SMA", overlay=false, max_labels_count=500)

// === Общие настройки ===
refreshTf = input.string("1", "Интервал обновления спреда", options=["1S", "5S", "10S", "30S", "1"])
alertFreq = input.string("once_per_bar_close", "Частота alert()", options=["once_per_bar", "once_per_bar_close", "all"])
alertFrequency = alertFreq == "once_per_bar" ? alert.freq_once_per_bar : alertFreq == "once_per_bar_close" ? alert.freq_once_per_bar_close : alert.freq_all

// Функция расчета спреда в % (симметричный вариант)
spreadPercent(a, b) =>
    base = (a + b) / 2.0
    base == 0.0 ? na : math.abs(a - b) / base * 100.0

// Функция обработки пары
processPair(enabled, pairName, symAraw, symBraw, threshold, tf) =>
    symA = str.trim(symAraw)
    symB = str.trim(symBraw)

    hasA = str.length(symA) > 0
    hasB = str.length(symB) > 0

    // Используем input.symbol + ignore_invalid_symbol=true, чтобы не ломать весь индикатор при проблемном тикере.
    closeA = enabled and hasA ? request.security(symA, tf, close, ignore_invalid_symbol=true) : na
    closeB = enabled and hasB ? request.security(symB, tf, close, ignore_invalid_symbol=true) : na

    symbolsValid = enabled and hasA and hasB and not na(closeA) and not na(closeB)
    spr = symbolsValid ? spreadPercent(closeA, closeB) : na

    isTriggered = symbolsValid and not na(spr) and spr >= threshold
    isCrossUp = isTriggered and (na(spr[1]) or spr[1] < threshold)

    if isCrossUp
        alert(
             "Спред выше порога: " + pairName +
             " | " + symA + " vs " + symB +
             " | Спред: " + str.tostring(spr, "#.##") + "%" +
             " | Порог: " + str.tostring(threshold, "#.##") + "%" +
             " | TF: " + tf,
             alertFrequency
         )

    [spr, isTriggered, symbolsValid]

